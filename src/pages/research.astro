---
import Layout from "@/layouts/Layout.astro";
import { profile } from "@/settings";
import BetterIcon from "@/components/ui/BetterIcon.astro";
import List from "@/components/ui/List.astro";
import { RESEARCH_ICONS } from "@/data/researchIcons";

const { research_areas } = profile;
---

<Layout title="Research | Yuting Sun">
    <div class="prose max-w-none">
        <h1 class="text-3xl font-bold mb-8">Research Statement</h1>

        <div class="mb-12">
            <p class="text-lg mb-6">
                Hi! I am the first year PhD student in Linguistics at University
                of Alberta (Supervisior: Anja Arnhold).
            </p>
            <p class="text-lg mb-6">
                Studying from China to Japan, to the Netherlands, and then to
                Canada, I am lucky enough to have the experience and ability to
                explore different countries. From a city which snow rarely to a
                city which rain alomst daily, and then to the city which snow
                alomst six monthes, I am also luck enough to experience
                different climates. I am a langauge lover and sports lover, and
                I would like to explore more.
            </p>
        </div>

        <h2 class="text-2xl font-bold mb-6">Research Areas</h2>
        <div class="grid gap-8 mb-12">
            {
                research_areas.map((area) => (
                    <div class="flex gap-6 items-start">
                        <BetterIcon>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke-width="2"
                                class="size-6 stroke-accent"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d={
                                        RESEARCH_ICONS[
                                            area.field as keyof typeof RESEARCH_ICONS
                                        ]?.path ||
                                        RESEARCH_ICONS["computer-science"].path
                                    }
                                />
                            </svg>
                        </BetterIcon>
                        <div>
                            <h3 class="text-xl font-semibold mb-2">
                                {area.title}
                            </h3>
                            <p class="text-base">{area.description}</p>
                        </div>
                    </div>
                ))
            }
        </div>

        <List
            listTitle="Current Projects"
            listItems={[
                {
                    title: "Radioactivity Studies",
                    description:
                        "Investigation of radioactive properties in uranium minerals and isolation of new radioactive elements.",
                },
                {
                    title: "Measurement Techniques",
                    description:
                        "Development of precise methods for measuring radioactive emissions and their properties.",
                },
            ]}
        />

        <h2 class="text-2xl font-bold mb-6">Research Interests</h2>
        <p class="text-lg mb-6">
            Speech perception and production; second langauge acquistion; L2 and
            Heritage speakers; Multimodal (e.g., beat gesture)
        </p>
    </div>
</Layout>
