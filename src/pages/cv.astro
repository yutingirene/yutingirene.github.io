---
import Layout from "@/layouts/Layout.astro";
import {
    experiences,
    education,
    honours,
    publications,
    conferences,
} from "../data/cv";

import type {
    Experience,
    Education,
    Publication,
    Conference,
    Honour,
} from "../types/cv";

import CvTimeline from "@/components/ui/CvTimeline.astro";
import List from "@/components/ui/List.astro";
import PublicationsList from "@/components/ui/PublicationsList.astro";

let orderedExperiences: Experience[] = [];
let orderedEducations: Education[] = [];
let orderedHonours: Honour[] = [];
let orderedPublications: Publication[] = [];
let orderedConference: Conference[] = [];

const presentKeywords = ["present", "now", "current", "today"];

const parseEndDate = (timeRange: string): number => {
    // Normalise " - ", "--", en-dash, em-dash, etc.
    const normalized = timeRange.replace(/\s*[-–—]\s*/g, "--");
    const parts = normalized.split("--");
    const end = parts.length > 1 ? parts[1].trim() : parts[0].trim();

    if (presentKeywords.includes(end.toLowerCase())) return Infinity;

    // Replace dots with dashes so new Date() can parse e.g. 2024.10 → 2024-10
    const isoLike = end.replace(/\./g, "-");
    const d = new Date(isoLike);
    return isNaN(d.getTime()) ? 0 : d.getTime();
};

const orderElement = <T extends { time: string }>(a: T, b: T) =>
    parseEndDate(b.time) - parseEndDate(a.time);

if (experiences.length > 0) {
    orderedExperiences = [...experiences].sort(orderElement);
}

if (education.length > 0) {
    orderedEducations = [...education].sort(orderElement);
}

if (publications.length > 0) {
    orderedPublications = [...publications].sort(orderElement);
}

if (conferences.length > 0) {
    orderedConference = [...conferences].sort(orderElement);
}

if (honours.length > 0) {
    orderedHonours = [...honours].sort(orderElement);
}
---

<Layout>
    {
        orderedEducations.length > 0 && (
            <section class="mb-12">
                <h2 class="text-2xl font-bold mb-6 border-b pb-2">Education</h2>
                <CvTimeline elements={orderedEducations} colored={true} />
            </section>
        )
    }

    {
        orderedExperiences.length > 0 && (
            <section class="mb-12">
                <h2 class="text-2xl font-bold mb-6 border-b pb-2">
                    Experiences
                </h2>
                <CvTimeline elements={orderedExperiences} colored={true} />
            </section>
        )
    }

    {
        orderedPublications.length > 0 && (
            <section class="mb-12">
                <h2 class="text-2xl font-bold mb-6 border-b pb-2">
                    Publications
                </h2>
                <PublicationsList elements={orderedPublications} />
            </section>
        )
    }

    {
        orderedHonours.length > 0 && (
            <section class="mb-12">
                <List listTitle="Honours" listItems={orderedHonours} />
            </section>
        )
    }

    {
        orderedConference.length > 0 && (
            <section class="mb-12">
                <h2 class="text-2xl font-bold mb-6 border-b pb-2">
                    Conference
                </h2>
                <CvTimeline elements={orderedConference} colored={true} />
            </section>
        )
    }
</Layout>
