---
import { Image } from "astro:assets";

import SocialIcons from "./SocialIcons.astro";

const { fullName, title, institute, profilePicture } = Astro.props;
---

<div class="flex-1">
    <h1 class="text-4xl font-bold mb-4">
        Welcome! I'm <span class="text-secondary">{fullName}</span>
    </h1>
    <p class="text-xl text-gray-600 mb-4">
        {title}{institute ? ` at ${institute}` : ""}
    </p>
    <p class="text-lg mb-6">
        I am the first year PhD student in Linguistics at University of Alberta
        (Supervisior: Anja Arnhold). My academic journey has taken me across the
        globe—from China to Japan, the Netherlands, and now Canada. I feel
        incredibly fortunate to have the opportunity to explore so many diverse
        cultures and environments. Along the way, I’ve experienced everything
        from a city where it rarely snows, to one where it rains almost daily,
        to a place where winter lasts for six months. Outside of my studies, I
        am passionate about music, learning languages, and playing sports, and I
        am always eager to discover new interests.
    </p>
    <div class="flex gap-4">
        <SocialIcons />
    </div>
</div>
<div class="size-72 lg:block hidden">
    <!-- Add your profile image -->
    <Image
        src={profilePicture}
        alt={fullName}
        class="w-full h-full mask mask-circle size-44"
    />
</div>
